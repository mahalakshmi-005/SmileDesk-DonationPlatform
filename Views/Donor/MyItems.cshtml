@model List<DonationItem>
@{ ViewData["Title"] = "My Items"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-800 mb-0">My donation items</h4>
            <p class="text-muted small mb-0">Manage your posted items and respond to NGO requests</p>
        </div>
        <a href="/Donor/PostItem" class="btn btn-success"><i class="ti ti-plus"></i>Post new item</a>
    </div>

    @if (!Model.Any())
    {
        <div class="sd-card text-center py-5">
            <div class="stat-icon-box icon-green mx-auto mb-3" style="width:60px;height:60px;font-size:1.6rem"><i class="ti ti-package"></i></div>
            <h5 class="fw-700">No items posted yet</h5>
            <p class="text-muted">Post your first item and help NGOs in need.</p>
            <a href="/Donor/PostItem" class="btn btn-success">Post an item</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="sd-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-700 mb-0">@item.Title</h6>
                                <span class="badge-cat badge-@item.Status.ToString().ToLower()">@item.Status</span>
                            </div>
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge-cat badge-other small">@item.Category</span>
                                <span class="badge-cat badge-other small">@item.Condition</span>
                            </div>
                            <p class="text-muted small mb-3">@item.Description</p>
                            <p class="text-muted small mb-3"><i class="ti ti-clock"></i> @item.PostedOn.ToString("dd MMM yyyy")</p>

                            @if (item.Status == DonationItemStatus.Available)
                            {
                                <div class="d-flex gap-2 mb-2">
                                    <a href="/Donor/EditItem/@item.Id" class="btn btn-sm btn-outline-secondary flex-fill"><i class="ti ti-edit"></i> Edit</a>
                                    <form method="post" action="/Donor/DeleteItem" class="flex-fill" onsubmit="return confirm('Remove this item from listings?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="ti ti-trash"></i> Delete</button>
                                    </form>
                                </div>
                            }

                            @if (item.Requests.Any())
                            {
                                <hr class="my-3"/>
                                <div class="fw-700 small mb-2">Requests (@item.Requests.Count)</div>
                                @foreach (var req in item.Requests)
                                {
                                    <div class="p-2 rounded-2 mb-2" style="background:var(--sd-slate-50);border:1px solid var(--sd-slate-200)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-600 small">@req.NGOProfile?.OrganizationName</div>
                                                <div class="text-muted" style="font-size:.75rem">@req.Message</div>
                                            </div>
                                            <span class="badge-cat badge-@req.Status.ToString().ToLower() ms-2" style="font-size:.7rem;white-space:nowrap">@req.Status</span>
                                        </div>
                                        @if (req.Status == ItemRequestStatus.Pending)
                                        {
                                            <div class="d-flex gap-2 mt-2">
                                                <form method="post" action="/Donor/RespondToRequest">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@req.Id" />
                                                    <input type="hidden" name="accept" value="true" />
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="ti ti-check"></i> Accept</button>
                                                </form>
                                                <form method="post" action="/Donor/RespondToRequest">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@req.Id" />
                                                    <input type="hidden" name="accept" value="false" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="ti ti-x"></i> Decline</button>
                                                </form>
                                            </div>
                                        }
                                        else if (req.Status == ItemRequestStatus.Accepted)
                                        {
                                            <div class="mt-2 p-2 rounded-2" style="background:#fff7e0">
                                                <p class="small mb-2"><i class="ti ti-phone"></i> Contact the NGO to arrange pickup, then confirm below once handed over.</p>
                                                <form method="post" action="/Donor/ConfirmHandover">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@req.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success w-100"><i class="ti ti-truck-delivery"></i> Confirm handover complete</button>
                                                </form>
                                            </div>
                                        }
                                        else if (req.Status == ItemRequestStatus.PickedUp)
                                        {
                                            <p class="small text-success mt-2 mb-0"><i class="ti ti-circle-check"></i> Picked up on @req.PickedUpOn?.ToString("dd MMM yyyy")</p>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model AdminDashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="dashboard-layout">
    <div class="sd-sidebar">
        <div class="sidebar-section-label">Admin panel</div>
        <a href="/Admin/Dashboard"     class="sidebar-link active"><i class="ti ti-layout-dashboard"></i> Dashboard</a>
        <a href="/Admin/NGOs"          class="sidebar-link"><i class="ti ti-building-community"></i> NGOs</a>
        <a href="/Admin/Donors"        class="sidebar-link"><i class="ti ti-users"></i> Donors</a>
        <a href="/Admin/Events"        class="sidebar-link"><i class="ti ti-calendar-event"></i> Events</a>
        <a href="/Admin/Donations"     class="sidebar-link"><i class="ti ti-heart-handshake"></i> Donations</a>
        <a href="/Admin/ItemDonations" class="sidebar-link"><i class="ti ti-package"></i> Item donations</a>
        <hr/>
        <form method="post" action="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-link border-0 bg-transparent w-100 text-start text-danger">
                <i class="ti ti-logout-2"></i> Logout
            </button>
        </form>
    </div>

    <div class="dashboard-content">
        <h4 class="fw-800 mb-4">Admin overview</h4>

        <div class="row g-3 mb-5">
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-green"><i class="ti ti-users"></i></div>
                    <div><div class="stat-value">@Model.TotalDonors</div><div class="stat-label">Total donors</div></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-teal"><i class="ti ti-building-community"></i></div>
                    <div><div class="stat-value">@Model.TotalNGOs</div><div class="stat-label">Approved NGOs</div></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-amber"><i class="ti ti-clock-hour-4"></i></div>
                    <div><div class="stat-value">@Model.PendingNGOApprovals</div><div class="stat-label">Pending approvals</div></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-blue"><i class="ti ti-package"></i></div>
                    <div><div class="stat-value">@Model.TotalDonationItems</div><div class="stat-label">Items listed</div></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-green"><i class="ti ti-currency-rupee"></i></div>
                    <div><div class="stat-value">&#8377;@Model.TotalFundsRaised.ToString("N0")</div><div class="stat-label">Total funds raised</div></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="stat-icon-box icon-teal"><i class="ti ti-receipt"></i></div>
                    <div><div class="stat-value">@Model.TotalMoneyDonations</div><div class="stat-label">Transactions</div></div>
                </div>
            </div>
        </div>

        @if (Model.PendingNGOs.Any())
        {
            <div class="sd-card mb-4">
                <div class="card-body p-0">
                    <div class="d-flex justify-content-between align-items-center p-3 pb-0">
                        <h6 class="fw-700 mb-0"><i class="ti ti-bell-ringing"></i> Pending NGO approvals</h6>
                        <span class="badge bg-warning text-dark">@Model.PendingNGOs.Count</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table sd-table mb-0">
                            <thead>
                                <tr><th>Organization</th><th>Reg. no.</th><th>Location</th><th>Applied on</th><th>Action</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var ngo in Model.PendingNGOs)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="ngo-avatar"><i class="ti ti-building-community"></i></div>
                                                <div>
                                                    <div class="fw-600">@ngo.OrganizationName</div>
                                                    <div class="text-muted small">@ngo.User?.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted small">@ngo.RegisterNumber</td>
                                        <td class="text-muted small">@ngo.City, @ngo.State</td>
                                        <td class="text-muted small">@ngo.CreatedOn.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <form method="post" action="/Admin/ApproveNGO">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ngo.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="ti ti-check"></i> Approve</button>
                                                </form>
                                                <form method="post" action="/Admin/RejectNGO" onsubmit="return confirm('Reject and remove this NGO?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ngo.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="ti ti-x"></i> Reject</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div class="sd-card">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center p-3 pb-0">
                    <h6 class="fw-700 mb-0"><i class="ti ti-heart-handshake"></i> Recent donations</h6>
                    <a href="/Admin/Donations" class="small text-success">View all</a>
                </div>
                <div class="table-responsive">
                    <table class="table sd-table mb-0">
                        <thead>
                            <tr><th>Donor</th><th>NGO</th><th>Amount</th><th>Date</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.RecentDonations)
                            {
                                <tr>
                                    <td class="fw-600 small">@d.DonorProfile?.DonorName</td>
                                    <td class="text-muted small">@d.NGOProfile?.OrganizationName</td>
                                    <td class="fw-700 text-success">&#8377;@d.Amount.ToString("N0")</td>
                                    <td class="text-muted small">@d.DonatedOn.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

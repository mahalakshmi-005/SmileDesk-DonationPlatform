@model NGOProfileViewModel
@{ ViewData["Title"] = "Register Your NGO"; }

<div class="container py-5">
    <div class="sd-form-card" style="max-width:640px">
        <div class="text-center mb-4">
            <div class="stat-icon-box icon-green mx-auto mb-3" style="width:56px;height:56px;font-size:1.6rem"><i class="ti ti-building-community"></i></div>
            <h2 class="fw-800 mb-1">Register your NGO</h2>
            <p class="text-muted small">Fill in your organization details. Admin will review and approve within 24 hours.</p>
        </div>

        <form asp-action="CreateProfile" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="OrganizationName" class="form-label">Organization name</label>
                    <input asp-for="OrganizationName" class="form-control" placeholder="Full legal name of the NGO" />
                    <span asp-validation-for="OrganizationName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="RegisterNumber" class="form-label">Registration number</label>
                    <input asp-for="RegisterNumber" class="form-control" placeholder="NGO reg. no." />
                    <span asp-validation-for="RegisterNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+91 XXXXX XXXXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="StreetName" class="form-label">Street address</label>
                    <input asp-for="StreetName" class="form-control" placeholder="Street name, area" />
                </div>
                <div class="col-md-4">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" placeholder="Chennai" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Pincode" class="form-label">Pincode</label>
                    <input asp-for="Pincode" class="form-control" placeholder="600001" maxlength="6" />
                    <span asp-validation-for="Pincode" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control" placeholder="Tamil Nadu" />
                </div>
                <div class="col-12">
                    <label asp-for="Country" class="form-label">Country</label>
                    <input asp-for="Country" class="form-control" value="India" />
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label">About your NGO</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="What does your NGO do? Who do you serve?"></textarea>
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-success w-100 py-2 fw-700">Submit for approval <i class="ti ti-arrow-right"></i></button>
                </div>
            </div>
        </form>
    </div>
</div>

@model MoneyDonation
@{ ViewData["Title"] = "Payment Successful"; }

<div class="container py-5" style="max-width:500px">
    <div class="sd-card text-center p-5">
        <div class="success-icon"><i class="ti ti-circle-check-filled"></i></div>
        <h2 class="fw-800 mb-2">Payment successful</h2>
        <p class="text-muted mb-4">Thank you for your generous donation</p>

        <div class="p-4 rounded-3 mb-4" style="background:#fff7e0;border:1px solid #ffe6ee">
            <div class="amount-display mb-1">&#8377;@Model.Amount.ToString("N0")</div>
            <p class="text-muted small mb-0">donated to <strong>@Model.NGOProfile?.OrganizationName</strong></p>
            @if (Model.NGOEvent != null)
            {
                <span class="badge bg-success mt-1"><i class="ti ti-target-arrow"></i> @Model.NGOEvent.Title</span>
            }
            @if (Model.RoutedToNgo)
            {
                <p class="small text-success mt-2 mb-0"><i class="ti ti-arrow-right-circle"></i> Sent directly to the NGO's account via Razorpay Route</p>
            }
        </div>

        <div class="text-start small mb-4">
            <div class="d-flex justify-content-between py-1 border-bottom">
                <span class="text-muted">Payment ID</span>
                <span class="fw-600 text-truncate ms-2" style="max-width:180px">@Model.RazorpayPaymentId</span>
            </div>
            <div class="d-flex justify-content-between py-1 border-bottom">
                <span class="text-muted">Order ID</span>
                <span class="fw-600 text-truncate ms-2" style="max-width:180px">@Model.RazorpayOrderId</span>
            </div>
            <div class="d-flex justify-content-between py-1">
                <span class="text-muted">Date</span>
                <span class="fw-600">@Model.DonatedOn.ToString("dd MMM yyyy, hh:mm tt")</span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="/Donor/Dashboard" class="btn btn-success flex-fill">Go to dashboard</a>
            <a href="/Home/Events" class="btn btn-outline-secondary flex-fill">Donate again</a>
        </div>
    </div>
</div>

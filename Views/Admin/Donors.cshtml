@model List<DonorProfile>
@{ ViewData["Title"] = "Manage Donors"; }

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-800 mb-0">All donors</h4>
        <span class="badge bg-secondary fs-6">@Model.Count total</span>
    </div>

    <div class="sd-table">
        <table class="table mb-0">
            <thead>
                <tr><th>Donor</th><th>Mobile</th><th>Contribution type</th><th>Location</th><th>Joined</th></tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="donor-avatar">@(d.DonorName.Substring(0,1).ToUpper())</div>
                                <div>
                                    <div class="fw-600">@d.DonorName</div>
                                    <div class="text-muted small">@d.User?.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted small">@d.MobileNumber</td>
                        <td><span class="badge-cat badge-clothes">@d.ContributionType</span></td>
                        <td class="text-muted small">@d.City, @d.State</td>
                        <td class="text-muted small">@d.User?.CreatedOn.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

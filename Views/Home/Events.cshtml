@model List<NGOEvent>
@{ ViewData["Title"] = "Events"; }

<div class="container py-5">
    <div class="section-eyebrow"><i class="ti ti-compass"></i> Explore</div>
    <h2 class="section-title mb-4">All NGO events</h2>

    @if (ViewBag.NgoFilterName != null)
    {
        <div class="action-banner mb-4">
            <div class="d-flex gap-3 align-items-center">
                <i class="ti ti-building-community" style="font-size:1.4rem;color:var(--sd-pink)"></i>
                <div>Showing events from <strong>@ViewBag.NgoFilterName</strong></div>
            </div>
            <a href="/Home/Events" class="btn btn-sm btn-outline-secondary">Clear filter</a>
        </div>
    }

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="/Home/Events" class="btn btn-sm @(ViewBag.Category == null ? "btn-success" : "btn-outline-secondary")">All</a>
        @foreach (var cat in Enum.GetValues<EventCategory>())
        {
            <a href="/Home/Events?category=@cat" class="btn btn-sm @(ViewBag.Category == cat.ToString() ? "btn-success" : "btn-outline-secondary")">@cat</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="ti ti-calendar-off" style="font-size:2.8rem;opacity:.3"></i>
            <p class="mt-3">No events in this category yet.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ev in Model)
            {
                <div class="col-md-4 reveal">
                    <div class="sd-card h-100">
                        @if (!string.IsNullOrEmpty(ev.ImagePath))
                        {
                            <img src="@ev.ImagePath" class="card-img-top" alt="@ev.Title" />
                        }
                        else
                        {
                            <div class="item-icon-tile"><i class="ti ti-target-arrow"></i></div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge-cat badge-@ev.Category.ToString().ToLower()">@ev.Category</span>
                                <small class="text-muted"><i class="ti ti-calendar"></i> @ev.EventDate.ToString("dd MMM yyyy")</small>
                            </div>
                            <div class="card-title">@ev.Title</div>
                            <p class="text-muted small flex-grow-1"><i class="ti ti-building-community me-1"></i>@ev.NGOProfile?.OrganizationName</p>
                            <p class="small text-muted mb-2">@(ev.Description.Length > 80 ? ev.Description[..80] + "..." : ev.Description)</p>
                            @if (ev.FundingGoal.HasValue && ev.FundingGoal > 0)
                            {
                                var pct = Math.Min(100, (int)(ev.FundsRaised / ev.FundingGoal.Value * 100));
                                <div class="progress mb-1"><div class="progress-bar" style="width:@pct%"></div></div>
                                <div class="d-flex justify-content-between small text-muted mb-2">
                                    <span>&#8377;@ev.FundsRaised.ToString("N0") raised</span>
                                    <span>@pct%</span>
                                </div>
                            }
                            <div class="d-flex gap-2 mt-auto">
                                <a href="/Home/EventDetail/@ev.Id" class="btn btn-sm btn-outline-secondary flex-fill">View</a>
                                @if (User.IsInRole("Donor"))
                                {
                                    <a href="/Donor/Donate?ngoId=@ev.NGOProfileId&eventId=@ev.Id" class="btn btn-sm btn-success flex-fill"><i class="ti ti-heart"></i>Donate</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

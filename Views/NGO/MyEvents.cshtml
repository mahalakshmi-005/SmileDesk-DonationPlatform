@model List<NGOEvent>
@{ ViewData["Title"] = "My Events"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-800 mb-0">My events</h4>
            <p class="text-muted small mb-0">All events posted by your NGO</p>
        </div>
        <a href="/NGO/PostEvent" class="btn btn-success"><i class="ti ti-plus"></i>Post new event</a>
    </div>

    @if (!Model.Any())
    {
        <div class="sd-card text-center py-5">
            <div class="stat-icon-box icon-green mx-auto mb-3" style="width:60px;height:60px;font-size:1.6rem"><i class="ti ti-calendar-event"></i></div>
            <h5 class="fw-700">No events posted yet</h5>
            <p class="text-muted">Create your first event to start receiving donations.</p>
            <a href="/NGO/PostEvent" class="btn btn-success">Post an event</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ev in Model)
            {
                <div class="col-md-6">
                    <div class="sd-card h-100">
                        @if (!string.IsNullOrEmpty(ev.ImagePath))
                        {
                            <img src="@ev.ImagePath" class="card-img-top" alt="@ev.Title" />
                        }
                        else
                        {
                            <div class="item-icon-tile"><i class="ti ti-target-arrow"></i></div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge-cat badge-@ev.Category.ToString().ToLower()">@ev.Category</span>
                                @if (ev.IsActive)
                                { <span class="badge-cat badge-approved"><i class="ti ti-point-filled"></i> Active</span> }
                                else
                                { <span class="badge-cat badge-rejected"><i class="ti ti-point-filled"></i> Inactive</span> }
                            </div>
                            <div class="card-title">@ev.Title</div>
                            <p class="text-muted small"><i class="ti ti-calendar"></i> @ev.EventDate.ToString("dd MMM yyyy")</p>

                            @if (ev.FundingGoal.HasValue && ev.FundingGoal > 0)
                            {
                                var pct = Math.Min(100, (int)(ev.FundsRaised / ev.FundingGoal.Value * 100));
                                <div class="progress mb-1"><div class="progress-bar" style="width:@pct%"></div></div>
                                <div class="d-flex justify-content-between small text-muted mb-2">
                                    <span>&#8377;@ev.FundsRaised.ToString("N0") raised</span>
                                    <span>Goal: &#8377;@ev.FundingGoal.Value.ToString("N0")</span>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small">&#8377;@ev.FundsRaised.ToString("N0") raised (no goal set)</p>
                            }

                            <p class="text-muted small mb-3 mt-auto">Posted @ev.PostedOn.ToString("dd MMM yyyy")</p>

                            <div class="d-flex gap-2">
                                <a href="/NGO/EditEvent/@ev.Id" class="btn btn-sm btn-outline-secondary flex-fill"><i class="ti ti-edit"></i> Edit</a>
                                <form method="post" action="/NGO/DeleteEvent" class="flex-fill" onsubmit="return confirm('Remove this event?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@ev.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="ti ti-trash"></i> Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model DonorProfileViewModel
@{ ViewData["Title"] = "Complete Your Profile"; }

<div class="container py-5">
    <div class="sd-form-card" style="max-width:600px">
        <div class="text-center mb-4">
            <div class="stat-icon-box icon-green mx-auto mb-3" style="width:56px;height:56px;font-size:1.6rem"><i class="ti ti-heart-handshake"></i></div>
            <h2 class="fw-800 mb-1">Complete your donor profile</h2>
            <p class="text-muted small">Tell us a bit about yourself to get started</p>
        </div>

        <form asp-action="CreateProfile" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="DonorName" class="form-label">Full name</label>
                    <input asp-for="DonorName" class="form-control" placeholder="Your name" />
                    <span asp-validation-for="DonorName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ContributionType" class="form-label">Contribution type</label>
                    <select asp-for="ContributionType" class="form-select" asp-items="Html.GetEnumSelectList<ContributionType>()">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="DateOfBirth" class="form-label">Date of birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="MobileNumber" class="form-label">Mobile number</label>
                    <input asp-for="MobileNumber" class="form-control" placeholder="+91 XXXXX XXXXX" />
                    <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DoorNo" class="form-label">Door no.</label>
                    <input asp-for="DoorNo" class="form-control" placeholder="12A" />
                </div>
                <div class="col-md-9">
                    <label asp-for="StreetName" class="form-label">Street name</label>
                    <input asp-for="StreetName" class="form-control" placeholder="Anna Nagar, 2nd Street" />
                </div>
                <div class="col-md-4">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" placeholder="Chennai" />
                </div>
                <div class="col-md-4">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control" placeholder="Tamil Nadu" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Country" class="form-label">Country</label>
                    <input asp-for="Country" class="form-control" value="India" />
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-success w-100 py-2 fw-700">Save profile and continue <i class="ti ti-arrow-right"></i></button>
                </div>
            </div>
        </form>
    </div>
</div>

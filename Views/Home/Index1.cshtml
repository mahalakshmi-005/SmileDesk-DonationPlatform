@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center" style="max-width:500px">
    <div class="stat-icon-box icon-red mx-auto mb-3" style="width:72px;height:72px;font-size:2rem;border-radius:20px"><i class="ti ti-alert-triangle"></i></div>
    <h2 class="fw-800 mt-3">Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred. Please try again, or head back to the homepage.</p>
    <a href="/" class="btn btn-success"><i class="ti ti-home"></i> Back to home</a>
</div>
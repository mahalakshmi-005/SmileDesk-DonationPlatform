@model List<DonationItem>
@{
    ViewData["Title"] = "Browse Donation Items";
    Func<ItemCategory, string> iconFor = c => c switch {
        ItemCategory.Clothes => "ti-shirt",
        ItemCategory.Furniture => "ti-sofa",
        ItemCategory.Electronics => "ti-device-laptop",
        ItemCategory.Books => "ti-book",
        ItemCategory.Food => "ti-bowl",
        ItemCategory.Medical => "ti-first-aid-kit",
        _ => "ti-package"
    };
}

<div class="container py-5">
    <div class="section-eyebrow"><i class="ti ti-package"></i> Available items</div>
    <h4 class="fw-800 mb-1">Browse donor items</h4>
    <p class="text-muted mb-4">Request items that donors have listed for your NGO</p>

    @if (!Model.Any())
    {
        <div class="sd-card text-center py-5">
            <div class="stat-icon-box icon-green mx-auto mb-3" style="width:60px;height:60px;font-size:1.6rem"><i class="ti ti-package"></i></div>
            <h5 class="fw-700">No items available right now</h5>
            <p class="text-muted">Donors haven't posted any items yet. Check back later.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="sd-card h-100">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="card-img-top" alt="@item.Title" />
                        }
                        else
                        {
                            <div class="item-icon-tile"><i class="ti @iconFor(item.Category)"></i></div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge-cat badge-clothes">@item.Category</span>
                                <span class="badge-cat badge-other">@item.Condition</span>
                            </div>
                            <div class="card-title">@item.Title</div>
                            <p class="text-muted small flex-grow-1">@(item.Description.Length > 90 ? item.Description[..90] + "..." : item.Description)</p>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <div class="donor-avatar">@(item.DonorProfile?.DonorName.Substring(0,1).ToUpper())</div>
                                <div>
                                    <div class="fw-600 small">@item.DonorProfile?.DonorName</div>
                                    <div class="text-muted" style="font-size:.72rem">@item.DonorProfile?.City, @item.DonorProfile?.State</div>
                                </div>
                            </div>
                            <button class="btn btn-sm btn-success w-100"
                                    data-bs-toggle="modal"
                                    data-bs-target="#requestModal"
                                    data-itemid="@item.Id"
                                    data-title="@item.Title">
                                <i class="ti ti-hand-stop"></i>Request this item
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="requestModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-700"><i class="ti ti-mail-forward"></i> Request item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/NGO/RequestItem">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="itemIdInput" name="itemId" />
                    <div class="p-3 rounded-3 mb-3" style="background:#fff7e0;border:1px solid #ffe6ee">
                        <p id="itemTitleDisplay" class="fw-700 mb-0 text-success"></p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message to donor <span class="text-danger">*</span></label>
                        <textarea name="message" class="form-control" rows="3"
                                  placeholder="Explain why your NGO needs this item and how it will be used..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success px-4"><i class="ti ti-send"></i> Send request</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('requestModal').addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        document.getElementById('itemIdInput').value = btn.dataset.itemid;
        document.getElementById('itemTitleDisplay').innerHTML = '<i class="ti ti-package"></i> ' + btn.dataset.title;
        window.SmileDeskIcons.render(document.getElementById('itemTitleDisplay'));
    });
</script>
}
